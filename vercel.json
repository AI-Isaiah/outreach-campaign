{
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python@4.3",
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron/scan-replies",
      "schedule": "*/30 * * * *"
    }
  ]
}
