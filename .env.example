# === Required ===
SUPABASE_DB_URL=postgresql://user:password@host:5432/dbname

# API authentication secret (required in production)
API_SECRET_KEY=change-me-to-a-random-string

# JWT secret for user auth tokens (required in production/staging)
# WARNING: When JWT_SECRET is unset, auth is bypassed and all requests return user_id=1 (dev mode)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# === Email ===
SMTP_PASSWORD=your-app-password-here
EMAIL_VERIFY_API_KEY=your-zerobounce-or-hunter-key

# === URLs (for Gmail OAuth redirects) ===
# FRONTEND_URL=https://your-domain.com
# BACKEND_URL=https://your-api.com

# === AI / Research ===
ANTHROPIC_API_KEY=your-anthropic-api-key
PERPLEXITY_API_KEY=your-perplexity-api-key

# === Google OAuth (Gmail sending & reply scanning) ===
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/gmail/callback

# === Token encryption (Fernet key for OAuth tokens at rest) ===
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# === Production deployment ===
# ENVIRONMENT=production
# ALLOWED_ORIGINS=https://your-domain.com
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_TRACES_SAMPLE_RATE=0.1
# PORT=8000
# WEB_CONCURRENCY=4
# LOG_LEVEL=INFO
# RATE_LIMIT_ENABLED=true

# === Frontend Sentry (browser error tracking) ===
# VITE_SENTRY_DSN=https://your-frontend-sentry-dsn@sentry.io/project-id

# Founder email (for allowed_emails seeding)
FOUNDER_EMAIL=your-email@example.com
