calendly_url: "https://calendly.com/your-handle"
physical_address: "Your Company, Street, City, Country"

smtp:
  host: "smtp.gmail.com"
  port: 587
  username: "outreach@your-secondary-domain.com"
  # password in .env as SMTP_PASSWORD

email_verification:
